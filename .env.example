# Client environment (exposed to the browser — never put secrets here).
# Copy to `.env` and adjust. Validated in src/lib/env.ts.

VITE_APP_NAME="MediSure"

# Base URL of the MedySure backend API. Required for auth (Google OAuth) and any
# real data fetching. Leave unset to keep feature pages on mock data.
#   Local dev:  http://127.0.0.1:3000/api/v1  (use 127.0.0.1, not localhost — see README/memory)
#   Production: https://medysure-backend.onrender.com/api/v1  (set in .env.production)
VITE_API_BASE_URL="http://127.0.0.1:3000/api/v1"
