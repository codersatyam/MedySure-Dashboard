# Production client environment. Loaded by Vite during `vite build` (prod mode).
# Never put secrets here (everything VITE_* is exposed to the browser).

VITE_APP_NAME="MediSure"

# MedySure backend API (Express + Supabase) deployed on Render.
VITE_API_BASE_URL="https://medysure-backend.onrender.com/api/v1"
